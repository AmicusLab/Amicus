# Configuration Encryption Key (REQUIRED)
# Used to encrypt/decrypt sensitive fields in ./data/amicus.json
# Generate with: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=change-me-strong-passphrase-min-32-chars

# Admin Authentication (OPTIONAL)
# If not set, admin endpoints will be disabled
AMICUS_ADMIN_PASSWORD=change-me-admin-password

# Admin Session Secret (OPTIONAL)
# Falls back to CONFIG_ENCRYPTION_KEY if not set
AMICUS_ADMIN_SESSION_SECRET=change-me-session-secret

# MCP GitHub Integration (OPTIONAL)
# Only needed if using MCP GitHub server
GITHUB_TOKEN=ghp_your_github_personal_access_token

# MCP Server Configuration Path (OPTIONAL)
# Default: ./data/mcp-servers.json
# MCP_CONFIG_PATH=./data/mcp-servers.json

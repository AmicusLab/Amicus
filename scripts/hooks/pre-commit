#!/bin/bash
set -e
echo "🔍 Pre-commit checks..."

echo "  ▸ Typechecking..."
bun run typecheck 2>&1
echo "  ✅ Typecheck passed"

echo "  ▸ Building..."
bun run build 2>&1
echo "  ✅ Build passed"

echo "  ▸ Running tests..."
bun run test 2>&1
echo "  ✅ Tests passed"

echo "✅ All checks passed. Committing..."
